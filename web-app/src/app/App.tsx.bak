      </div>
      <div className="pt-3 border-t border-border/30 space-y-2.5">
        <div className="h-3 w-20 bg-muted/20 rounded" />
        {[0.7, 0.55, 0.65, 0.5].map((w, i) => (
          <div
            key={i}
            className="h-3 bg-muted/15 rounded"
            style={{ width: `${w * 100}%` }}
          />
        ))}
      </div>
    </div>
  );
}

